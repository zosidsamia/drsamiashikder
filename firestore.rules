# Firestore Security Rules
# Deploy to Firebase Console > Firestore Database > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Patients collection
    // Allow authenticated users to read/write patient data
    match /patients/{patientId} {
      allow read, write: if request.auth != null;
      
      // Medical records sub-collection
      match /medicalRecords/{recordId} {
        allow read, write: if request.auth != null;
      }
      
      // Prescriptions sub-collection
      match /prescriptions/{prescriptionId} {
        allow read, write: if request.auth != null;
      }
      
      // Lab results sub-collection
      match /labResults/{labId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Medical records collection (flat structure)
    match /medicalRecords/{recordId} {
      allow read, write: if request.auth != null;
    }
    
    // Prescriptions collection
    match /prescriptions/{prescriptionId} {
      allow read, write: if request.auth != null;
    }
    
    // Appointments collection
    match /appointments/{appointmentId} {
      allow read, write: if request.auth != null;
    }
    
    // User profiles collection
    // Users can only read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
    
    // Staff directory (read-only for staff)
    match /staff/{staffId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == staffId || 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Audit logs (admin only)
    match /auditLogs/{logId} {
      allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth != null;
    }
  }
}
