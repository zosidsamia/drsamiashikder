{
  "name": "dr-samia-care-backend",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "check": "biome check src",
    "fix": "biome check --write src",
    "start": "node dist/index.js",
    "migrate": "node --loader ts-node/esm src/db/migrate.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@supabase/supabase-js": "^2.38.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.9.0",
    "typescript": "^5.8.3",
    "tsx": "^4.7.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.22.4"
  }
}
